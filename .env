# ============================================================
# SOC PROJECT - Environment Variables
# ⚠️ PENTING: Jangan commit file ini ke Git! (Sudah masuk .gitignore)
# File ini menyimpan kredensial utama untuk seluruh stack SOC.
# ============================================================

# --- 1. Wazuh Indexer (Database Alert) ---
# Digunakan untuk login ke https://localhost:9200 (direct) dan dashboard.
INDEXER_PASSWORD=WazuhSOC@2024!

# --- 2. Wazuh Dashboard (Visualisasi) ---
# Digunakan oleh sistem internal dashboard untuk berkomunikasi dengan indexer.
DASHBOARD_PASSWORD=KibanaSOC@2024!

# --- 3. Wazuh API (Manajemen Agent) ---
# Digunakan oleh Dashboard untuk memanggil API Manager (Port 55000).
# ⚠️ Password ini HARUS SAMA dengan yang ada di config/wazuh_dashboard.yml!
API_PASSWORD=WazuhAPI@2024!

# --- 4. DVWA Target (Honeypot) ---
# Password root database untuk DVWA.
DVWA_DB_PASSWORD=DVWApass@2024!

# --- 5. External Integrations (Opsional) ---
# AlienVault OTX: Dapatkan di https://otx.alienvault.com
OTX_API_KEY=PASTE_YOUR_OTX_API_KEY_HERE

# Ngrok: Dapatkan di https://dashboard.ngrok.com
# Token ini digunakan oleh script ngrok untuk membuat tunnel publik.
NGROK_AUTHTOKEN=3Ck2MZbyyM8i0KnfOB5BvQ0Mg6K_4ToiPTtN1PzpXkBXMKtDB
