# ============================================================
# Mini SOC - Environment Template (safe for public repo)
# Copy this file to .env and replace all placeholder values.
# ============================================================

# Wazuh Indexer admin password
INDEXER_PASSWORD=change-me-strong-password

# Wazuh Dashboard service password (kibanaserver user)
DASHBOARD_PASSWORD=change-me-strong-password

# Wazuh API user password (wazuh-wui user)
API_PASSWORD=change-me-strong-password

# DVWA MariaDB root password
DVWA_DB_PASSWORD=change-me-db-password

# AlienVault OTX API key (optional if OTX integration is enabled)
OTX_API_KEY=replace-with-your-otx-api-key

# Ngrok authtoken (optional if using public tunnel)
NGROK_AUTHTOKEN=replace-with-your-ngrok-authtoken
