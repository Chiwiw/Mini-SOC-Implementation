# ============================================================
# .gitattributes - SOC Project
# Enforce line endings untuk shell scripts
# ============================================================

# Shell scripts HARUS LF (Linux line endings)
# Jika tidak, container Linux akan error: "/bin/bash^M: bad interpreter"
*.sh text eol=lf
*.py text eol=lf

# Windows scripts boleh CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Config files menggunakan LF (di-mount ke container Linux)
*.conf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf

# Dockerfile
Dockerfile* text eol=lf
